# Auto detect text files and perform LF normalization
* text=auto

# Force text files to have LF line endings
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.css text eol=lf

# Force batch files to have CRLF line endings
*.bat text eol=crlf
