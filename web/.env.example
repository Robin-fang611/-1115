# ===========================================
# 环境变量配置文件
# ===========================================
# 使用说明：
# 1. 复制此文件为 .env.local 用于本地开发
# 2. 在 Vercel 部署时，将这些变量添加到 Vercel 项目设置中
# ===========================================

# ===========================================
# 后台管理认证
# ===========================================
# 后台管理登录密码
ADMIN_PASSWORD=61157252bB@

# ===========================================
# NextAuth 配置
# ===========================================
# NextAuth 密钥 - 用于会话加密
# 生产环境请使用强随机密钥
# 生成方法：openssl rand -base64 32
# 或者使用 Node.js: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=hT7xK9mP2vL5nQ8wR3yF6jC4bN1aS0dE9uI7oG5hZ2k=

# NextAuth URL - 当前应用的基础 URL
# 本地开发使用 http://localhost:3000
# 部署到 Vercel 后改为：https://your-domain.vercel.app
# Vercel 会自动设置此变量，但建议手动配置以确保一致性
NEXTAUTH_URL=http://localhost:3000

# ===========================================
# 邮件配置（可选）- 用于联系表单功能
# ===========================================
# 邮箱服务配置，如需启用联系表单邮件通知功能，请取消注释并填写
# EMAIL_SERVER=smtp://username:password@smtp.example.com:587
# EMAIL_FROM=noreply@example.com

# ===========================================
# 其他配置（可选）
# ===========================================
# 调试模式（生产环境请关闭）
NEXT_PUBLIC_DEBUG=false
