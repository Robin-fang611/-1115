# ===========================================
# 环境变量配置文件
# ===========================================
# 使用说明：
# 1. 复制此文件为 .env.local 用于本地开发
# 2. 在 Vercel 部署时，将这些变量添加到 Vercel 项目设置中
# ===========================================

# ===========================================
# 后台管理认证
# ===========================================
# 后台管理登录密码（明文）
ADMIN_PASSWORD=61157252bB@

# 后台管理登录密码（加密后的哈希值，优先使用）
# 生成方法：node -e "console.log(require('bcryptjs').hashSync('your-password', 10))"
# ADMIN_PASSWORD_HASH=

# ===========================================
# 数据存储配置
# ===========================================
# 数据文件存储路径（可选）
# 如果不设置，默认使用项目内的 src/data 目录
# 在 Vercel 等平台部署时，可以设置为持久化存储路径
# DATA_PATH=/path/to/persistent/storage

# ===========================================
# 邮件配置（可选）- 用于联系表单功能
# ===========================================
# 邮箱服务配置，如需启用联系表单邮件通知功能，请取消注释并填写
# EMAIL_SERVER=smtp://username:password@smtp.example.com:587
# EMAIL_FROM=noreply@example.com

# ===========================================
# 其他配置（可选）
# ===========================================
# 调试模式（生产环境请关闭）
NEXT_PUBLIC_DEBUG=false

# Node 环境
NODE_ENV=development
